{
  /*
   * TypeScript configuration for the Next.js frontend.
   *
   * Key settings:
   *  - target: ES2017 — wide browser support while keeping modern syntax
   *  - strict: true — enables all strict type-checking options
   *  - moduleResolution: "bundler" — required by Next.js (and Vite); resolves
   *    modules using the same algorithm as bundlers like webpack / Turbopack
   *  - jsx: "react-jsx" — the modern JSX transform (no need to import React)
   *  - incremental: true — enables `.tsbuildinfo` for faster subsequent builds
   *  - paths["@/*"] — the `@/` import alias used throughout the project,
   *    mapped to the project root so `@/components/ui/Button` works everywhere
   */

  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
